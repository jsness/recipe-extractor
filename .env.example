HTTP_ADDR=:8080
DATABASE_URL=postgres://postgres:postgres@localhost:5433/recipes?sslmode=disable

# Extractor backend: openai or anthropic
EXTRACTOR=anthropic
LLM_ONLY_EXTRACTION=false

# OpenAI settings for recipe normalization
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_PROJECT_ID=
OPENAI_ORGANIZATION_ID=
OPENAI_TIMEOUT_SECONDS=45

# Anthropic settings for recipe normalization
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_TIMEOUT_SECONDS=45
